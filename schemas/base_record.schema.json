{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BaseRecord",
  "type": "object",
  "required": [
    "id",
    "patient_id",
    "event_date",
    "status",
    "source"
  ],
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "patient_id": {
      "type": "string",
      "minLength": 1
    },
    "event_date": {
      "type": "string",
      "format": "date"
    },
    "status": {
      "type": "string",
      "minLength": 1
    },
    "source": {
      "type": "object",
      "required": [
        "document_id",
        "file_name",
        "relative_path",
        "ingested_at"
      ],
      "properties": {
        "document_id": {
          "type": "string"
        },
        "file_name": {
          "type": "string"
        },
        "relative_path": {
          "type": "string"
        },
        "ingested_at": {
          "type": "string",
          "format": "date-time"
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}

